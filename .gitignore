# ===== TRACK =====
# CLAUDE.md          - main config
# docs/              - coding standards
# skills/            - custom slash commands (skill format)
# settings.json      - permissions config (no secrets)

# ===== IGNORE EVERYTHING ELSE =====

# Session & runtime state
debug/
todos/
tasks/
ide/
plans/
sessions/
session-env/
shell-snapshots/
file-history/
paste-cache/

# Memory (auto-generated, conversation-specific)
memory/

# Per-project memory (auto-generated, machine-specific)
projects/

# Profiling artefacts
default.profraw
*.profraw

# History (sensitive - contains conversation data)
history*.jsonl

# Telemetry & analytics
statsig/
telemetry/
stats-cache.json
mcp-needs-auth-cache.json

# Cache
cache/

# Plugins (nested git repos)
plugins/

# Backups (auto-generated)
backups/

# Credentials & secrets
credentials.json
*.key
*.pem
*.token
auth/
oauth/

# Logs and cache
*.log
*.cache

# OS cruft
.DS_Store
Thumbs.db

# Temp files
*.tmp
*.swp
*~

# Project-relative scratch directory (see DOCUMENTATION.md §"Reviewing doc changes")
tmp/
