# ===== TRACK =====
# CLAUDE.md          - main config
# docs/              - coding standards
# commands/          - custom slash commands
# settings.json      - permissions config (no secrets)

# ===== IGNORE EVERYTHING ELSE =====

# Session & runtime state
debug/
todos/
tasks/
ide/
plans/
sessions/
session-env/
shell-snapshots/
file-history/
paste-cache/

# Per-project memory (auto-generated, machine-specific)
projects/

# History (sensitive - contains conversation data)
history*.jsonl

# Telemetry & analytics
statsig/
telemetry/
stats-cache.json
mcp-needs-auth-cache.json

# Cache
cache/

# Plugins (nested git repos)
plugins/

# Backups (auto-generated)
backups/

# Credentials & secrets
credentials.json
*.key
*.pem
*.token
auth/
oauth/

# Logs and cache
*.log
*.cache

# OS cruft
.DS_Store
Thumbs.db

# Temp files
*.tmp
*.swp
*~
